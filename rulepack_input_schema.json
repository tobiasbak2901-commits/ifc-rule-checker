{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ifc-rule-checker.local/schemas/rulepack_input_schema.json",
  "title": "Rulepack Input",
  "type": "object",
  "required": [
    "rulepack",
    "classes",
    "defaults",
    "rules"
  ],
  "properties": {
    "rulepack": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "author",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z_][a-z0-9_]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "keywords",
          "path_candidates"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "keywords": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "path_candidates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "defaults": {
      "type": "object",
      "required": [
        "constraints"
      ],
      "properties": {
        "constraints": {
          "type": "object",
          "required": [
            "max_move_m",
            "z_move_allowed"
          ],
          "properties": {
            "max_move_m": {
              "type": "number",
              "minimum": 0
            },
            "z_move_allowed": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "check",
          "severity"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "class_in": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "relation": {
            "type": "string",
            "minLength": 1
          },
          "applies_to": {
            "type": "object",
            "properties": {
              "class_in": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "relation": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "check": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "min_clearance"
                ]
              },
              "min_distance_m": {
                "type": "number",
                "minimum": 0
              }
            },
            "additionalProperties": true
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error"
            ]
          },
          "explain_short": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
